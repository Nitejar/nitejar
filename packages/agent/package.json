{
  "name": "@nitejar/agent",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./network-policy": {
      "types": "./dist/network-policy.d.ts",
      "import": "./dist/network-policy.js",
      "default": "./dist/network-policy.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js",
      "default": "./dist/runner.js"
    },
    "./steer-arbiter": {
      "types": "./dist/steer-arbiter.d.ts",
      "import": "./dist/steer-arbiter.js",
      "default": "./dist/steer-arbiter.js"
    },
    "./streaming": {
      "types": "./dist/streaming.d.ts",
      "import": "./dist/streaming.js",
      "default": "./dist/streaming.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "import": "./dist/memory.js",
      "default": "./dist/memory.js"
    },
    "./prompt-builder": {
      "types": "./dist/prompt-builder.d.ts",
      "import": "./dist/prompt-builder.js",
      "default": "./dist/prompt-builder.js"
    },
    "./prompt-sanitize": {
      "types": "./dist/prompt-sanitize.d.ts",
      "import": "./dist/prompt-sanitize.js",
      "default": "./dist/prompt-sanitize.js"
    },
    "./openrouter-usage": {
      "types": "./dist/openrouter-usage.d.ts",
      "import": "./dist/openrouter-usage.js",
      "default": "./dist/openrouter-usage.js"
    },
    "./mention-parser": {
      "types": "./dist/mention-parser.d.ts",
      "import": "./dist/mention-parser.js",
      "default": "./dist/mention-parser.js"
    },
    "./tracing": {
      "types": "./dist/tracing.d.ts",
      "import": "./dist/tracing.js",
      "default": "./dist/tracing.js"
    },
    "./sandboxes": {
      "types": "./dist/sandboxes.d.ts",
      "import": "./dist/sandboxes.js",
      "default": "./dist/sandboxes.js"
    },
    "./skill-sync": {
      "types": "./dist/skill-sync.d.ts",
      "import": "./dist/skill-sync.js",
      "default": "./dist/skill-sync.js"
    },
    "./skill-materialize": {
      "types": "./dist/skill-materialize.d.ts",
      "import": "./dist/skill-materialize.js",
      "default": "./dist/skill-materialize.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js",
      "default": "./dist/session.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./integrations/registry": {
      "types": "./dist/integrations/registry.d.ts",
      "import": "./dist/integrations/registry.js",
      "default": "./dist/integrations/registry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "eslint src __tests__ --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@nitejar/database": "workspace:*",
    "@nitejar/plugin-handlers": "workspace:*",
    "@nitejar/sprites": "workspace:*",
    "@tavily/core": "^0.7.1",
    "cron-parser": "^4.9.0",
    "diff": "^8.0.3",
    "openai": "^6.17.0"
  },
  "devDependencies": {
    "@nitejar/eslint-config": "workspace:*",
    "@nitejar/typescript-config": "workspace:*",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.10.5",
    "eslint": "^8.57.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
